                      <Expression Value="[total]" Type="Expression" />
                    </NameExpressionPair>
                    <NameExpressionPair Name="margenEstimado">
                      <Expression Value="[montoFacturado] - [costoEstimado]" Type="Expression" />
                    </NameExpressionPair>
                    <NameExpressionPair Name="esAtendida">
                      <Expression Value="if([id_estado]= 1, 1, 0)" Type="Expression" />
